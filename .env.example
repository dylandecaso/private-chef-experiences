# --- Email (existing) ---
# Resend API key from https://resend.com (Dashboard → API Keys).
RESEND_API_KEY=

# Where contact-form submissions are delivered.
# Multiple recipients: separate with commas (no spaces required).
CONTACT_TO_EMAIL=privatechefexperiences@gmail.com

# Sender shown in the inbox. Until you verify your own domain in Resend,
# leave it as the default sandbox sender (onboarding@resend.dev).
CONTACT_FROM_EMAIL=onboarding@resend.dev

# --- Admin panel ---
# Same Google OAuth Web Client ID, exposed to the browser (Vite needs the
# VITE_ prefix) AND used server-side to verify tokens.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Comma-separated whitelist of Google emails allowed into /admin.
ADMIN_EMAILS=dylandecaso1520@gmail.com,privatechefexperiences@gmail.com

# --- Vercel Blob ---
# Auto-injected by Vercel when you create the Blob store in the dashboard.
# Only needed locally if you use `vercel dev`.
BLOB_READ_WRITE_TOKEN=
